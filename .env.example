# ── TAS Hub environment variables ────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# Gemini API key — enables direct browser-side AI (no backend required).
# Get one at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Backend URL — your deployed tas-hub-backend (Render, Railway, etc.)
# Leave blank to run frontend-only (localStorage + direct Gemini).
VITE_API_URL=http://localhost:3001

# Shared API key between frontend and backend (set the same value in both)
VITE_API_KEY=tas-hub-local-key-2026

# Access PINs — override the defaults (8474 admin / 8888 field) here.
# These are baked into the frontend build, so treat this file as a secret.
VITE_ADMIN_PIN=8474
VITE_FIELD_PIN=8888
